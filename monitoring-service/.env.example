# Used by docker compose for: grafana + monitoring-service containers.
# Copy to .env: cp .env.example .env

# --- Grafana (first login at http://localhost:3000) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
GF_USERS_ALLOW_SIGN_UP=false
GF_SERVER_HTTP_PORT=3000
GF_INSTALL_PLUGINS=

# --- OpenStack (optional — enables Nova VM/host metrics in monitoring microservice) ---
# OS_AUTH_URL=https://controller:5000/v3
# OS_PROJECT_NAME=admin
# OS_USERNAME=
# OS_PASSWORD=
# OS_USER_DOMAIN_NAME=Default
# OS_PROJECT_DOMAIN_NAME=Default
