# ── guacd ─────────────────────────────────────────
GUACD_HOST=guacd
GUACD_PORT=4822

# ── VM / RDP (REQUIRED) ───────────────────────────
VM_HOST=192.168.66.210
VM_PORT=3389
VM_USERNAME=ubuntu
VM_PASSWORD=ubuntu
VM_PROTOCOL=rdp
VM_DOMAIN=
VM_SECURITY=any

# ── Display defaults ──────────────────────────────
VM_WIDTH=1280
VM_HEIGHT=720
VM_DPI=96

# ── RDP feature flags ─────────────────────────────
VM_COLOR_DEPTH=32
VM_RESIZE_METHOD=display-update
VM_ENABLE_WALLPAPER=true
VM_ENABLE_FONT_SMOOTHING=true
VM_ENABLE_FULL_WINDOW_DRAG=true
VM_ENABLE_DESKTOP_COMP=true
VM_ENABLE_MENU_ANIMATIONS=true
VM_DISABLE_BITMAP_CACHING=false
VM_CLIENT_NAME=vdi-mirroring
