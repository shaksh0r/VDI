# VDI Docker Compose - copy to .env and fill in

# Database (used by monitoring and other services)
POSTGRES_DB=vdi
POSTGRES_USER=vdi
POSTGRES_PASSWORD=changeme
# If host port 5432 is busy: use 5433 (connect from host with psql -p 5433; containers still use database:5432)
# POSTGRES_PUBLISH_PORT=5433

# OpenStack (for monitoring-service VM/host metrics from Nova)
OS_AUTH_URL=https://your-openstack:5000/v3
OS_PROJECT_NAME=admin
OS_USERNAME=admin
OS_PASSWORD=changeme
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default

# Grafana (first login)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Resend — transactional email (https://resend.com)
# Verify a domain in the Resend dashboard, then use e.g. "VDI Labs <noreply@yourdomain.com>"
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=VDI Labs <noreply@yourdomain.com>
# Optional
# RESEND_REPLY_TO=support@yourdomain.com

# Provisioning / lab deploy API (provisioning_service)
# DB_* fall back to POSTGRES_* then defaults (vdi / localhost)
DB_HOST=database
DB_PORT=5432
DB_NAME=vdi
DB_USER=vdi
DB_PASSWORD=changeme
NOVA_COMPUTE_URL=https://your-openstack:8774/v2.1
OPENSTACK_TOKEN=
OPENSTACK_KEY_NAME=default-key
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://
# If set, POST /lab/deploy requires header X-Provisioning-Secret: <value>
PROVISIONING_INTERNAL_SECRET=
